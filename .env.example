# OAuth mode:
# - facebook: current default for a standard Meta app with Facebook Login + Instagram Graph API.
# - instagram: only for an app created through "API setup with Instagram login" with a separate Instagram App ID.
META_AUTH_MODE=facebook

# Required for OAuth URL generation and code exchange.
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=
META_INSTAGRAM_REDIRECT_URI=http://localhost:8787/callback
META_INSTAGRAM_SCOPES=instagram_basic,pages_show_list,pages_read_engagement,instagram_manage_insights,instagram_manage_comments

# Optional. If set, used before the local token store.
META_INSTAGRAM_ACCESS_TOKEN=

# Optional. Usually saved by meta_resolve_instagram_account after OAuth.
# Set manually only when Meta gives direct Instagram access but declines Page scopes.
META_INSTAGRAM_USER_ID=
META_FACEBOOK_PAGE_ID=

# Optional defaults.
META_GRAPH_API_VERSION=v25.0
META_TOKEN_STORE_PATH=
